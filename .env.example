# Database (PostgreSQL)
# .NET style:  Host=HOST;Port=5432;Database=DB_NAME;Username=USER;Password=PASSWORD
# or standard: postgres://USER:PASSWORD@HOST:5432/DB_NAME
DB_CONNECTION_STRING=Host=HOST;Port=5432;Database=DB_NAME;Username=USER;Password=PASSWORD

# JWT
JWT_SECRET=YOUR_JWT_SECRET
JWT_ISSUER=Finance Tracker API
JWT_AUDIENCE=Finance Tracker UI

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5011

# App
PORT=5197
API_PORT=5197
UI_PORT=5011
